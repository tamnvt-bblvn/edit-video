# Mẫu biến môi trường cho edit-video (web server & giới hạn upload).
# Ứng dụng đọc trực tiếp từ môi trường tiến trình — không tự nạp file .env.
# Sao chép thành .env và nạp theo công cụ bạn dùng (PowerShell, Docker -e, systemd EnvironmentFile, …).

# --- Logging (ứng dụng + uvicorn.access) ---
# Mức log: DEBUG | INFO | WARNING | ERROR (mặc định INFO). DEBUG còn ghi dòng lệnh FFmpeg trong edit_video.ffmpeg.
# EDIT_VIDEO_LOG_LEVEL=DEBUG

# Ghi tiến độ frame/fps của FFmpeg trực tiếp ra console (stderr không bị capture — nhiễu nhưng rất hữu ích khi điều tra treo / chậm).
# EDIT_VIDEO_FFMPEG_VERBOSE=1

# --- edit_video_web / uvicorn ---
EDIT_VIDEO_HOST=0.0.0.0
EDIT_VIDEO_PORT=8000

# Bật reload dev khi đổi mã (mặc định: bật). Production: 0 | false | no
# EDIT_VIDEO_RELOAD=0

# --- Giới hạn upload API ---
EDIT_VIDEO_MAX_UPLOAD_MB=500
EDIT_VIDEO_MAX_BATCH=25

# Số FFmpeg chạy song song trong một request batch (1–32; không set → min(4, số CPU))
# EDIT_VIDEO_BATCH_WORKERS=4
